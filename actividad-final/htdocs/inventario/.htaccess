# ============================================================
# Control de acceso — Solo personal autorizado
# ============================================================
# Este archivo debe estar en: C:\xampp\htdocs\inventario\.htaccess
# El archivo de contrasenas (.htpasswd) se guarda fuera de htdocs
# por seguridad, en: C:\xampp\passwords\.htpasswd
# ============================================================

AuthType Basic
AuthName "Acceso restringido — TecnoSoluciones S.A."
AuthUserFile "C:/xampp/passwords/.htpasswd"
Require valid-user
